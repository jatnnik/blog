---
import Layout from "../components/Layout.astro";
import About from "../components/About.astro";
import Blog from "../components/Blog.astro";
import SideProjects from "../components/SideProjects.astro";
---

<Layout>
  <div class="space-y-10">
    <div class="mt-8"></div>
    <!-- <About /> -->
    <div class="pb-8 text-center">
      <h1 class="text-4xl font-semibold tracking-tighter text-pretty">
        Welcome to my corner of the Internet!
      </h1>

      <p class="text-pretty mt-6 max-w-prose mx-auto">
        Hello, friend. This is my digital garden, a place where I write down
        things that I want to remember – maybe it's useful for you, too.
      </p>

      <p class="font-handwriting mt-6 text-xl text-rose-700 -rotate-3">
        Jannik
      </p>
    </div>
    <SideProjects />
    <Blog />
    <div class="mt-8"></div>
  </div>
</Layout>
